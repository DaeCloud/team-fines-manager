{
  "name": "team-fines-manager",
  "version": "1.2.11",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "build": "next build --turbopack && npx tsc server.ts --outDir . --module commonjs --esModuleInterop --skipLibCheck --resolveJsonModule 2>/dev/null; echo build done",
    "start": "node server.js",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "build:docker": "next build"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.35.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "prisma": "5.22.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@eslint/eslintrc": "^3.3.1"
  }
}
